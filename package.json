        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/test-utils": "^2.4.10",
        "@vue/vue3-jest": "^29.2.6",
        "cross-env": "^7.0.3",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jest": "^28.9.0",
